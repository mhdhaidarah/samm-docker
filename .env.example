# SAMM Docker — env vars referenced by docker-compose.yml.
# Generated from this template by install.sh on first run. Edit then
# `docker compose up -d` to apply.

# Postgres password (auto-generated). Changing this on an existing install
# requires `docker compose down -v` first, which WIPES the database — back up
# the pgdata + etcsamm volumes before rotating.
POSTGRES_PASSWORD=__GENERATED_POSTGRES_PASSWORD__

# Public host: the LAN IP MikroTik NAS will hit for RADIUS 1812/1813.
# install.sh auto-detects from `ip route`; override if multi-homed.
SAMM_PUBLIC_HOST=__DETECTED_HOST__

# Host port for the SAMM admin + customer portal (default 8000).
SAMM_API_PORT=8000

# Timezone for log timestamps inside containers (any tzdata zone).
TZ=UTC

# ── WhatsApp QR bridge (unofficial Baileys sidecar) ──────────────────────────
# Shared bearer token between samm-api/notification and the wa-bridge image
# (auto-generated). The bridge runs as part of the stack but idles until you
# pick the "qr" WhatsApp provider; the official Meta Cloud API needs none of it.
WA_BRIDGE_TOKEN=__GENERATED_WA_BRIDGE_TOKEN__
