# SAMM Docker — env vars referenced by docker-compose.yaml.
#
# Manual quickstart:
#   cp .env.example .env
#   $EDITOR .env       # set POSTGRES_PASSWORD and SAMM_PUBLIC_HOST
#   docker compose up -d
#
# (Or use the one-line installer at
#  https://github.com/mhdhaidarah/samm-docker/releases/latest/download/install.sh
#  which generates this file for you.)

# Postgres password. Pick a strong random value, e.g.:
#   python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
# Changing this on an existing install requires `docker compose down -v` first,
# which WIPES the database — back up the pgdata + etcsamm volumes before rotating.
POSTGRES_PASSWORD=change-me-to-a-strong-random-value

# Public host: the LAN IP MikroTik NAS will hit for RADIUS 1812/1813.
# Use the docker host's LAN IP (e.g. 192.168.1.10), NOT 127.0.0.1 — MikroTik
# routers need to reach it over the network.
SAMM_PUBLIC_HOST=192.168.1.10

# Host port for the SAMM admin + customer portal (default 8000).
SAMM_API_PORT=8000

# Timezone for log timestamps inside containers (any tzdata zone, e.g.
# UTC, Asia/Beirut, Europe/Istanbul).
TZ=UTC
